    },
    {
      "id": "no_offside",
      "text": "那如果没有越位呢?最聪明的踢法,不是配合,是派前锋杵在对方门口等长传。两队都这么干,中场瞬间被掏空,足球就退化成互相开大脚。",
      "pitch": {
        "players": [
          {"team":"red","label":"9","keys":[[0,0.50,0.54],[1.6,0.50,0.13],[18,0.50,0.13]]},
          {"team":"blue","label":"4","keys":[[0,0.53,0.58],[1.6,0.50,0.20],[18,0.50,0.20]]},
          {"team":"blue","label":"9","keys":[[0,0.45,0.51],[3.2,0.50,0.88],[18,0.50,0.88]]},
